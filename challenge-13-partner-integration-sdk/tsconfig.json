{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "..",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src",
    "tests",
    "examples",
    "../shared/src",
    "../challenge-11-claim-assessment-agent/src",
    "../challenge-12-regulatory-rule-engine/src",
    "../challenge-14-workflow-orchestrator/src"
  ]
}
